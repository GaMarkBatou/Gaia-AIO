{
  "manifest_version": 3,
  "name": "Tardis",
  "description": "Time Activity Recording & Duration Intelligence System - WBCCKIL",
  "version": "1.1.2",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "64": "images/icon-64.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "notifications",
    "storage",
    "activeTab",
    "scripting",
    "sidePanel",
    "windows",
    "tabs",
    "tabGroups"
  ],
    "host_permissions": [
    "*://*/"
  ],
  "background": {},
  "content_scripts": [
    {
      "matches": ["https://desktop.wxcc-eu2.cisco.com/*"],
      "js": ["timelord.js"]
    },
	{
      "matches": ["https://analyzer-v2.wxcc-eu2.cisco.com/*"],
      "js": ["sidekick.js"],
	  "all_frames": true
    }
  ]
}
